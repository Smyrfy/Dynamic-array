#include <iostream>

int main() {
    int data[] = {1, 1, 2, 2, 2, 3, 1}, size = 7;
    int j = 0;
    for (int i = 1; i < size; i++) {
        if (data[i] != data[j]) data[++j] = data[i];
    }
    size = (size == 0) ? 0 : j + 1;
    for(int i=0; i<size; i++) std::cout << data[i] << " ";
    return 0;
}
