#include <iostream>

struct int_vector {
    int* data;
    int size;
    int capacity;
};

void pop_back(int_vector& v) {
    if (size > 0) v.size--;
}

int main() {
    int_vector v = { new int[5]{1, 2, 3}, 3, 5 };
    v.size--; // Видалили 3
    for(int i=0; i<v.size; i++) std::cout << v.data[i] << " ";
    return 0;
}
