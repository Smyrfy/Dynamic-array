#include <iostream>
#include <algorithm>

int main() {
    int data[] = {5, 2, 9, 1}, size = 4;
    for(int i=0; i<size-1; i++)
        for(int j=0; j<size-i-1; j++)
            if(data[j] > data[j+1]) std::swap(data[j], data[j+1]);
    for(int i=0; i<size; i++) std::cout << data[i] << " ";
    return 0;
}
